#!/bin/bash

output=$(nvidia-smi --query-gpu=utilization.gpu,temperature.gpu \
  --format=csv,noheader,nounits 2>/dev/null)

[[ -z "$output" ]] && echo '{"text": ""}' && exit 0

usage=$(echo "$output" | awk -F',' '{gsub(/ /,"",$1); print $1}')
temp=$(echo  "$output" | awk -F',' '{gsub(/ /,"",$2); print $2}')

echo "{\"text\": \"饇梄 ${usage}% ${temp}簞C\", \"tooltip\": \"GPU: ${usage}%\\nTemp: ${temp}簞C\"}"
